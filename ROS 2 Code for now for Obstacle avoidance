import rclpy
from rclpy.node import Node
from sensor_msgs.msg import LaserScan
from geometry_msgs.msg import Twist
import numpy as np

class ObstacleAvoidance(Node):
    def __init__(self):
        super().__init__('obstacle_avoidance')
        
        # TurtleBot3 Waffle Pi dimensions with EXTRA safety
        self.robot_width = 0.281  # Waffle Pi width
        self.robot_length = 0.306  # Waffle Pi length
        self.safety_margin = 0.25  # Increased safety margin
        
        # Distance thresholds
        self.front_threshold = 0.35  # Stop distance for front
        self.side_threshold = 0.45   # Larger threshold for sides (robot width + margin)
        self.turn_clearance = 0.50   # Need this much space to turn safely
        
        # Very conservative speeds
        self.max_linear_speed = 0.10
        self.max_angular_speed = 0.20
        self.acceleration_limit = 0.03
        
        # State tracking
        self.current_linear_vel = 0.0
        self.current_angular_vel = 0.0
        self.is_turning = False
        self.turn_direction = 0  # 1 for left, -1 for right
        
        self.subscriber = self.create_subscription(
            LaserScan,
            '/scan',
            self.scan_callback,
            10
        )
        self.publisher = self.create_publisher(
            Twist,
            '/cmd_vel',
            10
        )
        
        self.get_logger().info('TurtleBot3 Waffle Pi - Enhanced side protection enabled')
        self.get_logger().info(f'Side threshold: {self.side_threshold}m, Front: {self.front_threshold}m')
    
    def smooth_velocity_change(self, current, target, max_change):
        """Gradually change velocity"""
        if abs(target - current) <= max_change:
            return target
        elif target > current:
            return current + max_change
        else:
            return current - max_change
    
    def get_min_distance_in_range(self, msg, start_deg, end_deg):
        """Get minimum distance in a degree range"""
        num_ranges = len(msg.ranges)
        
        # Convert degrees to indices
        start_idx = int((start_deg % 360) * num_ranges / 360)
        end_idx = int((end_deg % 360) * num_ranges / 360)
        
        # Handle wrap-around
        if start_idx > end_idx:
            indices = list(range(start_idx, num_ranges)) + list(range(0, end_idx + 1))
        else:
            indices = list(range(start_idx, end_idx + 1))
        
        # Filter valid readings
        valid_ranges = []
        for i in indices:
            r = msg.ranges[i]
            if r > 0.0 and not np.isinf(r) and not np.isnan(r):
                valid_ranges.append(r)
        
        if not valid_ranges:
            return float('inf')
        
        return min(valid_ranges)
    
    def scan_callback(self, msg):
        twist = Twist()
        
        # Define much wider sectors to account for robot body
        # Front: -45 to +45 degrees (90 degree cone - WIDE)
        front_min = self.get_min_distance_in_range(msg, 315, 45)
        
        # Left side: 30 to 120 degrees (covers left flank during forward motion)
        left_side_min = self.get_min_distance_in_range(msg, 30, 120)
        
        # Right side: 240 to 330 degrees (covers right flank)
        right_side_min = self.get_min_distance_in_range(msg, 240, 330)
        
        # Extended side checks for turns (even wider)
        left_extended = self.get_min_distance_in_range(msg, 15, 135)
        right_extended = self.get_min_distance_in_range(msg, 225, 345)
        
        # Rear check (important during turns)
        rear_min = self.get_min_distance_in_range(msg, 135, 225)
        
        # Log all sensor data
        self.get_logger().info(
            f'F:{front_min:.2f} L:{left_side_min:.2f} R:{right_side_min:.2f} Rear:{rear_min:.2f}',
            throttle_duration_sec=0.5
        )
        
        # Check if all sides are safe
        front_safe = front_min > self.front_threshold
        left_safe = left_side_min > self.side_threshold
        right_safe = right_side_min > self.side_threshold
        left_turn_safe = left_extended > self.turn_clearance
        right_turn_safe = right_extended > self.turn_clearance
        
        target_linear = 0.0
        target_angular = 0.0
        
        if self.is_turning:
            # In turning mode - be extra cautious
            self.get_logger().info(f'TURNING MODE - Direction: {self.turn_direction}')
            
            # Only stop turning if there's clearance all around
            if front_safe and left_safe and right_safe and front_min > 0.6:
                self.is_turning = False
                self.turn_direction = 0
                target_linear = 0.0  # Don't move forward immediately
                target_angular = 0.0
                self.get_logger().info('Turn complete - Path clear')
            else:
                # Keep turning slowly
                target_linear = 0.0
                target_angular = self.turn_direction * self.max_angular_speed
        else:
            # Normal navigation mode
            
            # Check if ANY side is too close
            if not front_safe or not left_safe or not right_safe:
                # IMMEDIATE STOP - something too close
                self.is_turning = True
                target_linear = 0.0
                
                # Determine which side is problematic
                if not front_safe:
                    self.get_logger().warn(f'FRONT BLOCKED at {front_min:.2f}m - STOPPING')
                if not left_safe:
                    self.get_logger().warn(f'LEFT SIDE at {left_side_min:.2f}m - STOPPING')
                if not right_safe:
                    self.get_logger().warn(f'RIGHT SIDE at {right_side_min:.2f}m - STOPPING')
                
                # Choose turn direction based on which side has MORE space
                if left_turn_safe and left_extended > right_extended + 0.1:
                    self.turn_direction = 1  # Turn left
                    self.get_logger().info(f'Turning LEFT (L:{left_extended:.2f} > R:{right_extended:.2f})')
                elif right_turn_safe and right_extended > left_extended + 0.1:
                    self.turn_direction = -1  # Turn right
                    self.get_logger().info(f'Turning RIGHT (R:{right_extended:.2f} > L:{left_extended:.2f})')
                else:
                    # Default to left if unclear
                    self.turn_direction = 1
                    self.get_logger().info('Turning LEFT (default)')
                
                target_angular = self.turn_direction * self.max_angular_speed
            else:
                # All clear - safe to move forward
                target_linear = self.max_linear_speed
                target_angular = 0.0
        
        # Apply smooth velocity changes
        self.current_linear_vel = self.smooth_velocity_change(
            self.current_linear_vel, 
            target_linear, 
            self.acceleration_limit
        )
        self.current_angular_vel = self.smooth_velocity_change(
            self.current_angular_vel, 
            target_angular, 
            self.acceleration_limit
        )
        
        # Emergency override - if ANYTHING is really close, STOP immediately
        emergency_threshold = 0.25
        if front_min < emergency_threshold or left_side_min < emergency_threshold or right_side_min < emergency_threshold:
            self.current_linear_vel = 0.0
            self.get_logger().error(f'EMERGENCY STOP - Object at {min(front_min, left_side_min, right_side_min):.2f}m')
        
        twist.linear.x = self.current_linear_vel
        twist.angular.z = self.current_angular_vel
        
        self.publisher.publish(twist)

def main():
    rclpy.init()
    node = ObstacleAvoidance()
    
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        # Emergency stop
        stop_msg = Twist()
        node.publisher.publish(stop_msg)
        node.destroy_node()
        rclpy.shutdown()

if __name__ == '__main__':
    main()
