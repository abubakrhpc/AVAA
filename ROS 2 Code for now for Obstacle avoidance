#!/usr/bin/env python3
"""
TurtleBot3 Waffle Pi Obstacle Avoidance Node
============================================
This node implements simple reactive obstacle avoidance using LiDAR data.

Behavior:
- Subscribes to /scan (sensor_msgs/LaserScan)
- Publishes to /cmd_vel (geometry_msgs/Twist)
- If obstacle detected within SAFE_DISTANCE in front sectors, stops and turns
- Otherwise, moves forward at FORWARD_SPEED

Author: Created for TurtleBot3 Waffle Pi on ROS2 Humble
"""

import rclpy
from rclpy.node import Node
from rclpy.qos import QoSProfile, ReliabilityPolicy, HistoryPolicy
from sensor_msgs.msg import LaserScan
from geometry_msgs.msg import Twist
import numpy as np


class ObstacleAvoidance(Node):
    """
    Reactive obstacle avoidance node using LiDAR scan data.
    """
    
    def __init__(self):
        super().__init__('obstacle_avoidance')
        
        # ============================================================
        # PARAMETERS - Adjust these for different behaviors
        # ============================================================
        
        # Safety distance threshold (meters)
        # If obstacle closer than this, robot will stop and turn
        self.SAFE_DISTANCE = 0.5  # Conservative for real robot
        
        # Forward speed when path is clear (m/s)
        # TurtleBot3 Waffle Pi max: ~0.26 m/s, we use moderate speed
        self.FORWARD_SPEED = 0.15  # Safe moderate speed
        
        # Angular speed when turning to avoid obstacle (rad/s)
        # TurtleBot3 Waffle Pi max: ~1.82 rad/s, we use moderate turn
        self.TURN_SPEED = 0.5  # Moderate turning speed
        
        # Field of view angles to check for obstacles (degrees)
        # Front sector: checks from -FRONT_ANGLE to +FRONT_ANGLE
        self.FRONT_ANGLE = 30  # 60-degree cone in front
        
        # Left and right sector angles for deciding turn direction
        self.LEFT_ANGLE_START = 10   # Start of left check zone
        self.LEFT_ANGLE_END = 90     # End of left check zone
        self.RIGHT_ANGLE_START = -90  # Start of right check zone (negative)
        self.RIGHT_ANGLE_END = -10    # End of right check zone
        
        # ============================================================
        # ROS2 Setup
        # ============================================================
        
        # QoS profile for sensor data (matches typical LiDAR settings)
        # BEST_EFFORT reliability is standard for sensor data streams
        sensor_qos = QoSProfile(
            reliability=ReliabilityPolicy.BEST_EFFORT,
            history=HistoryPolicy.KEEP_LAST,
            depth=10
        )
        
        # Subscribe to LiDAR scan topic with appropriate QoS
        self.scan_subscription = self.create_subscription(
            LaserScan,
            '/scan',
            self.scan_callback,
            sensor_qos  # Use sensor QoS profile instead of just depth
        )
        
        # Publisher for velocity commands
        self.cmd_vel_publisher = self.create_publisher(
            Twist,
            '/cmd_vel',
            10
        )
        
        # Timer for publishing velocity commands at consistent rate
        # 10 Hz is good for reactive control
        self.timer = self.create_timer(0.1, self.timer_callback)
        
        # State variables
        self.obstacle_detected = False
        self.turn_direction = 1  # 1 for left (CCW), -1 for right (CW)
        self.latest_scan = None
        
        self.get_logger().info('Obstacle Avoidance Node Started')
        self.get_logger().info(f'Safe distance: {self.SAFE_DISTANCE}m')
        self.get_logger().info(f'Forward speed: {self.FORWARD_SPEED}m/s')
        self.get_logger().info(f'Turn speed: {self.TURN_SPEED}rad/s')
        self.get_logger().info('Ready to avoid obstacles!')
        
    def scan_callback(self, msg):
        """
        Callback for LiDAR scan messages.
        Processes scan data to detect obstacles and decide avoidance strategy.
        
        Args:
            msg (LaserScan): LiDAR scan message
        """
        self.latest_scan = msg
        
        # Calculate angle increment and total angles
        num_readings = len(msg.ranges)
        angle_min = msg.angle_min
        angle_increment = msg.angle_increment
        
        # Initialize lists to store distances in different sectors
        front_distances = []
        left_distances = []
        right_distances = []
        
        # Process each LiDAR reading
        for i, distance in enumerate(msg.ranges):
            # Skip invalid readings (inf, nan, or out of range)
            if np.isinf(distance) or np.isnan(distance):
                continue
            if distance < msg.range_min or distance > msg.range_max:
                continue
                
            # Calculate angle of this reading in degrees
            angle_deg = np.degrees(angle_min + i * angle_increment)
            
            # Normalize angle to [-180, 180]
            while angle_deg > 180:
                angle_deg -= 360
            while angle_deg < -180:
                angle_deg += 360
            
            # Categorize reading into sectors
            # Front sector: straight ahead
            if -self.FRONT_ANGLE <= angle_deg <= self.FRONT_ANGLE:
                front_distances.append(distance)
            
            # Left sector: for determining turn direction
            if self.LEFT_ANGLE_START <= angle_deg <= self.LEFT_ANGLE_END:
                left_distances.append(distance)
            
            # Right sector: for determining turn direction
            if self.RIGHT_ANGLE_START <= angle_deg <= self.RIGHT_ANGLE_END:
                right_distances.append(distance)
        
        # ============================================================
        # Obstacle Detection Logic
        # ============================================================
        
        # Check if obstacle in front sector is too close
        if front_distances:
            min_front_distance = min(front_distances)
            
            if min_front_distance < self.SAFE_DISTANCE:
                # Obstacle detected! Determine best turn direction
                self.obstacle_detected = True
                
                # Compare average distances on left vs right
                avg_left = np.mean(left_distances) if left_distances else 0
                avg_right = np.mean(right_distances) if right_distances else 0
                
                # Turn towards the side with more space
                if avg_left > avg_right:
                    self.turn_direction = 1  # Turn left (counter-clockwise)
                    direction_name = "LEFT"
                else:
                    self.turn_direction = -1  # Turn right (clockwise)
                    direction_name = "RIGHT"
                
                self.get_logger().info(
                    f'OBSTACLE at {min_front_distance:.2f}m! Turning {direction_name}'
                )
            else:
                # Path is clear
                self.obstacle_detected = False
        else:
            # No valid readings in front - be cautious and stop
            self.obstacle_detected = True
            self.turn_direction = 1
            self.get_logger().warn('No valid front readings - stopping')
    
    def timer_callback(self):
        """
        Timer callback to publish velocity commands at consistent rate.
        Called at 10 Hz to ensure smooth control.
        """
        # Create velocity command message
        cmd_vel = Twist()
        
        if self.obstacle_detected:
            # AVOIDANCE MODE: Stop forward motion and turn
            cmd_vel.linear.x = 0.0  # Stop moving forward
            cmd_vel.angular.z = self.turn_direction * self.TURN_SPEED
            
        else:
            # FORWARD MODE: Move forward, no turning
            cmd_vel.linear.x = self.FORWARD_SPEED
            cmd_vel.angular.z = 0.0
        
        # Publish the command
        self.cmd_vel_publisher.publish(cmd_vel)
    
    def destroy_node(self):
        """
        Clean shutdown: stop the robot before destroying node.
        """
        # Send stop command
        stop_cmd = Twist()  # All zeros
        self.cmd_vel_publisher.publish(stop_cmd)
        self.get_logger().info('Stopping robot and shutting down')
        super().destroy_node()


def main(args=None):
    """
    Main function to initialize and run the obstacle avoidance node.
    """
    # Initialize ROS2 Python client library
    rclpy.init(args=args)
    
    # Create the obstacle avoidance node
    obstacle_avoidance_node = ObstacleAvoidance()
    
    try:
        # Keep the node running
        rclpy.spin(obstacle_avoidance_node)
    except KeyboardInterrupt:
        # Handle Ctrl+C gracefully
        obstacle_avoidance_node.get_logger().info('Keyboard interrupt received')
    finally:
        # Clean up
        obstacle_avoidance_node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
